# MongoDB
# — Triển khai Docker Compose: KHÔNG cần sửa dòng này — docker-compose.yml ghi đè thành mongodb://mongo:27017
# — Chạy app bằng npm trên máy dev: map Mongo ra host trong compose (ví dụ 127.0.0.1:27017) rồi dùng mongodb://127.0.0.1:27017
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=evn_scraper

# Worker
WORKER_CONCURRENCY=3
TASK_POLL_INTERVAL_MS=5000

# Log: info (mặc định) | warn | error | debug (chi tiết từng PDF, captcha, poll rỗng)
LOG_LEVEL=info

# Playwright
PLAYWRIGHT_HEADLESS=true
# Mobile layout — ổn định react-select trên CPC (khuyến nghị true khi deploy)
PLAYWRIGHT_MOBILE_MODE=true
# Chờ N ms trước khi đóng trang (theo dõi tay); kết hợp HEADLESS=false
# PLAYWRIGHT_PAUSE_BEFORE_CLOSE_MS=60000

# Đăng nhập CSKH CPC (không commit file .env thật)
EVN_CPC_LOGIN_URL=https://cskh.cpc.vn/dang-nhap
EVN_CPC_LOGIN_USERNAME=
EVN_CPC_LOGIN_PASSWORD=
# Tra cứu hóa đơn điện tử (sau khi đăng nhập)
EVN_CPC_LOOKUP_URL=https://cskh.cpc.vn/dashboard/tra-cuu-hoa-don-dien-tu

# Nhận diện request đăng nhập
EVN_CPC_CHECK_EXIST_USER_URL_MATCH=check-exist-user

# anticaptcha.top — Image to Text Autodetect (type 14, phân biệt hoa/thường)
ANTICAPTCHA_API_KEY=
ANTICAPTCHA_API_URL=https://anticaptcha.top/api
ANTICAPTCHA_TYPE=14
ANTICAPTCHA_CASESENSITIVE=1

# CSKH NPC (Điện lực miền Bắc) — đăng nhập + lưu session
EVN_NPC_LOGIN_URL=https://cskh.npc.com.vn/home/AccountNPC
EVN_NPC_HOME_URL=https://cskh.npc.com.vn/home
# Sau đăng nhập — bước pipeline NPC (Dịch vụ TT CSKH)
EVN_NPC_INDEX_NPC_URL=https://cskh.npc.com.vn/DichVuTTCSKH/IndexNPC?index=2
# Origin site NPC (API same-origin sau đăng nhập)
#EVN_NPC_BASE_URL=https://cskh.npc.com.vn
# true: in thời gian từng bước login/captcha (tìm chỗ chậm ~1 phút)
#NPC_LOGIN_TRACE_TIMING=1
# Số lần thử tối đa khi NPC trả HTML "Mã xác thực không chính xác" (mặc định 5, tối đa 10)
#NPC_CAPTCHA_MAX_ATTEMPTS=5
# (Tuỳ chọn) test:npc-batch — khi npm không truyền được cờ, set tại đây:
#NPC_BATCH_KY=1
#NPC_BATCH_MONTH=03
#NPC_BATCH_YEAR=2026
#NPC_BATCH_TOTAL=20
#NPC_BATCH_SIZE=10
#NPC_BATCH_DELAY_MS=4000
#NPC_BATCH_SKIP=0
# Bắt buộc để API POST /api/npc/accounts mã hóa mật khẩu (chuỗi dài, không commit)
NPC_CREDENTIALS_SECRET=

# Import tài khoản NPC từ Excel khi khởi động app (`npm start` / Docker)
# Đặt file .xlsx vào thư mục data/ (cột A = username, B = password) — xem data/README.md
# AUTO_IMPORT_NPC_XLSX=false
# NPC_ACCOUNTS_XLSX_PATH=./data/npc-accounts.xlsx

# Thư mục lưu PDF tải về (tự động tạo)
PDF_OUTPUT_DIR=./output/pdfs

# Base URL API hóa đơn CPC
EVN_CPC_API_BASE_URL=https://cskh-api.cpc.vn/api
# Bảo vệ quota API PDF (CPC thường giới hạn 100 calls/phút)
EVN_CPC_PDF_MAX_PER_MINUTE=90
EVN_CPC_PDF_429_MAX_RETRIES=6
EVN_CPC_PDF_429_BASE_DELAY_MS=1500
# Retry sweep cho các file PDF lỗi trong cùng task
EVN_CPC_PDF_RETRY_SWEEPS=1
EVN_CPC_PDF_RETRY_SWEEP_DELAY_MS=30000

# HTTP API server (AutoCheck)
API_PORT=1371
# Public base URL để Agent Gateway gọi vào
EVN_AUTOCHECK_BASE_URL=https://evnservice.nguyentrungnam.com

# API-key auth cho AutoCheck API
API_KEY_AUTH_ENABLED=true
API_KEY=please-generate-a-strong-random-key

# (Tuỳ chọn) Seed task — dùng khi `npm run seed:task` không truyền được cờ (npm 10+)
# SEED_PERIOD=1
# SEED_MONTH=03
# SEED_YEAR=2026
